{
  "name": "md-pastebin",
  "version": "1.0.0",
  "description": "Markdown Pastebin — anonymous paste service with live preview",
  "main": "src/server/index.js",
  "scripts": {
    "start": "node src/server/index.js",
    "dev": "nodemon src/server/index.js",
    "test": "jest --runInBand",
    "test:server": "jest src/server/__tests__ --runInBand",
    "test:client": "jest public/__tests__ --runInBand"
  },
  "keywords": [
    "markdown",
    "pastebin",
    "express"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "express": "^4.21.2",
    "highlight.js": "^11.11.1",
    "marked": "^15.0.7",
    "nanoid": "^3.3.8"
  },
  "devDependencies": {
    "jest": "^29.7.0",
    "jsdom": "^24.1.3",
    "nodemon": "^3.1.9",
    "supertest": "^7.0.0"
  },
  "jest": {
    "testEnvironment": "node",
    "collectCoverageFrom": [
      "src/**/*.js",
      "public/**/*.js",
      "!**/__tests__/**"
    ]
  }
}
